# Backend environment — copy to .env on the server, do NOT commit
# Secrets (ONBOARDING_STMP_EMAIL, ONBOARDING_STMP_PASSWORD) are fetched
# from Infisical (path /canis-major) at runtime — no need to store them here.
# If Infisical is unavailable, these fallback values are used instead.
PORT=8083
SMTP_HOST=mail.paceyspace.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=no-reply@paceyspace.com
SMTP_PASS=
NOTIFY_TO=jordan@paceyspace.com
